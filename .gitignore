# ================================
*.hdsproj.user
*.hdsc_workspace
*.hproject
HDSC_IDE/
*.afx
*.afr

# ================================
# GCC ARM 工具链
# ================================
*.a

# ================================
# CMake 构建系统
# ================================
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt
compile_commands.json

# ================================
# PlatformIO
